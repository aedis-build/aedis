<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Aedis.App1.Worker</RootNamespace>
    <!-- Projeto autônomo: versiona seus próprios pacotes, sem depender do Directory.Packages.props da solução existente. -->
    <ManagePackageVersionsCentrally>false</ManagePackageVersionsCentrally>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Aedis.Hosting.Worker" Version="AEDIS_PKG_VERSION" />
    <PackageReference Include="Aedis.Messaging.RabbitMq" Version="AEDIS_PKG_VERSION" />
  </ItemGroup>

  <!--
    Para PERSISTIR reusando as camadas da sua solução, adicione as referências de projeto e injete seu
    repositório no handler (ver NotificationRequestedEventHandler):

    <ItemGroup>
      <ProjectReference Include="..\Aedis.App1.Application\Aedis.App1.Application.csproj" />
      <ProjectReference Include="..\Aedis.App1.Domain\Aedis.App1.Domain.csproj" />
      <ProjectReference Include="..\Aedis.App1.Infrastructure\Aedis.App1.Infrastructure.csproj" />
    </ItemGroup>
  -->

</Project>
