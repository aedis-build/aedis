    <ProjectReference Include="..\Aedis.Cache.Redis\Aedis.Cache.Redis.csproj" />
    <ProjectReference Include="..\Aedis.Database.Postgres\Aedis.Database.Postgres.csproj" />
    <ProjectReference Include="..\Aedis.Messaging.AwsSqs\Aedis.Messaging.AwsSqs.csproj" />
    <ProjectReference Include="..\Aedis.Observability.Otlp\Aedis.Observability.Otlp.csproj" />
    <ProjectReference Include="..\Aedis.Security.Keycloak\Aedis.Security.Keycloak.csproj" />
    <ProjectReference Include="..\Aedis.Diagnostics\Aedis.Diagnostics.csproj" />
  </ItemGroup>

</Project>
