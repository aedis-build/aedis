<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageId>Aedis.Build</PackageId>
    <Description>Aedis.Build — meta-pacote batteries-included: cura uma stack padrão (ASP.NET Core + Postgres + Redis + AWS SQS + OTLP + Keycloak + diagnostics).</Description>
